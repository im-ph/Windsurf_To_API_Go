# ========== Server ==========
PORT=3003
API_KEY=

# ========== Codeium Auth ==========
CODEIUM_API_KEY=
CODEIUM_AUTH_TOKEN=

# ========== Language Server ==========
# Leave blank to auto-resolve (in priority order):
#   1. this env var (explicit override)
#   2. <exe dir>/bin/language_server_linux_x64  (sibling file, scp-friendly)
#   3. /opt/windsurf/language_server_linux_x64  (legacy absolute path)
LS_BINARY_PATH=
LS_PORT=42100

# ========== Advanced ==========
CODEIUM_API_URL=https://server.self-serve.windsurf.com
DEFAULT_MODEL=claude-4.5-sonnet-thinking
MAX_TOKENS=8192
LOG_LEVEL=info

# ========== Dashboard ==========
DASHBOARD_PASSWORD=
